{
  "info": {
    "name": "AI Employee Performance Analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "employeeId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/signup",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Employees - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/employees",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Amit Sharma\",\n  \"email\": \"amit@example.com\",\n  \"department\": \"Engineering\",\n  \"skills\": [\"React\", \"Node.js\", \"MongoDB\"],\n  \"performanceScore\": 91,\n  \"experience\": 4\n}"
        }
      }
    },
    {
      "name": "Employees - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/employees"
      }
    },
    {
      "name": "Employees - Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/employees/search?department=Engineering&q=React"
      }
    },
    {
      "name": "Employees - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/employees/{{employeeId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"performanceScore\": 95,\n  \"experience\": 4.5\n}"
        }
      }
    },
    {
      "name": "AI - Recommend",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/ai/recommend",
        "body": { "mode": "raw", "raw": "{\n  \"employees\": []\n}" }
      }
    },
    {
      "name": "Employees - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/employees/{{employeeId}}"
      }
    }
  ]
}

